# Copy to .env next to docker-compose.yml, then fill in.
# Generate each secret with: openssl rand -hex 32

# Shared secret for the X-AO-Internal-Secret header. The SAME value goes into
# the thalamus Convex dashboard as AO_INTERNAL_SECRET.
AO_INTERNAL_SECRET=

# Postgres superuser password (user "ao", db "ao"). Only reachable from
# localhost on the VM; still, don't reuse the internal secret.
POSTGRES_PASSWORD=
