# Copy to .env next to docker-compose.yml, then fill in.
# Generate each secret with: openssl rand -hex 32

# Shared secret for the X-AO-Internal-Secret header. The SAME value goes into
# the thalamus Convex dashboard as AO_INTERNAL_SECRET.
AO_INTERNAL_SECRET=

# Postgres superuser password (user "ao", db "ao"). Only reachable from
# localhost on the VM; still, don't reuse the internal secret.
POSTGRES_PASSWORD=

# Public API hostname Caddy terminates TLS for (e.g. api.agentoverflow.example).
AO_API_HOST=

# Convex host the credit/LLM/MCP endpoints reverse-proxy to (the deployment's
# .convex.site host, e.g. befitting-wildebeest-866.convex.site).
AO_CONVEX_HOST=

# Optional: IndexNow key for instant Bing/Yandex submission. Must match the file
# hosted at https://<site>/<key>.txt (frontend/public/<key>.txt). Leave blank to
# disable. With it set, `docker compose exec api python -m app.indexnow` backfills
# the whole corpus.
AO_INDEXNOW_KEY=
